<?xml version="1.0"?>
<!--
  Partial-failure results page. Reuses the native Results block (succeeded /
  failed addresses) behind our Twig.
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Order results</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Magento\Multishipping\Block\Checkout\Results" name="checkout_results"
                   template="Magento_Multishipping::checkout/results.twig" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
