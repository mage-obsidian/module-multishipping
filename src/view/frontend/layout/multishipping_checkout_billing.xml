<?xml version="1.0"?>
<!--
  Step 3 — payment method. Reuses the native Billing block (available methods +
  selected billing address) behind our Twig. The Knockout payment UI is dropped;
  offline methods are native radios that POST to the billing controller. The
  payment_methods_before/after containers are kept for third-party method blocks.
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Billing Information</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Magento\Multishipping\Block\Checkout\Billing" name="checkout_billing"
                   template="Magento_Multishipping::checkout/billing.twig" cacheable="false">
                <arguments>
                    <argument name="checkout_data" xsi:type="object">Magento\Multishipping\Block\DataProviders\Billing</argument>
                </arguments>
                <container name="payment_methods_before" label="Payment Methods Before"/>
                <container name="payment_methods_after" label="Payment Methods After"/>
            </block>
        </referenceContainer>
    </body>
</page>
