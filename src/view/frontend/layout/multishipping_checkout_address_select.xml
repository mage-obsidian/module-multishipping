<?xml version="1.0"?>
<!--
  Billing-address picker. Reuses the native Address\Select block (the customer's
  address book) behind our Twig.
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Change Billing Address</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Magento\Multishipping\Block\Checkout\Address\Select" name="checkout_address_select"
                   template="Magento_Multishipping::checkout/address/select.twig" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
